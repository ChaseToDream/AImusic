{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AI Music Generator",
  "version": "0.1.0",
  "identifier": "com.aimusicgenerator.app",
  "build": {
    "beforeDevCommand": "cd ../web && npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd ../web && npm run build",
    "frontendDist": "../web/.next"
  },
  "app": {
    "title": "AI Music Generator",
    "windows": [
      {
        "title": "AI Music Generator",
        "width": 1024,
        "height": 768,
        "minWidth": 768,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
